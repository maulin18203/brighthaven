# ─── BrightHaven Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values

# Flask
FLASK_SECRET_KEY=brighthaven_2026_mk_secure_change_me

# MQTT Broker (EMQX Cloud or HiveMQ)
MQTT_BROKER=broker.emqx.io
MQTT_PORT=8883
MQTT_USERNAME=cloud_admin
MQTT_PASSWORD=your_mqtt_password_here
MQTT_USE_TLS=true

# Blynk — ESP8266 Board (BrightHaven template, TMPL3wjTF3gGK)
BLYNK_TOKEN_ESP8266=your_esp8266_blynk_token_here

# Blynk — ESP32 Board (BrightHaven1 template, TMPL3n_dCuyOY)
BLYNK_TOKEN_ESP32=your_esp32_blynk_token_here

# Firebase
FIREBASE_KEY_PATH=firebase_key.json
